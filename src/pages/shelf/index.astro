---
import BaseLayout from '@layouts/Layout.astro';
import TerminalWindow from '@components/TerminalWindow.astro';
import { getShelfCatalog, getShelfStats } from '@services/shelf.service';

const catalog = await getShelfCatalog();
const books = catalog.books;
const stats = await getShelfStats(books);

const statusOrder = ['reading', 'completed', 'paused', 'unread'];
const statusConfig: Record<string, { label: string; color: string; icon: string }> = {
  reading:   { label: 'Reading',   color: 'text-cyan-400',   icon: '▶' },
  completed: { label: 'Completed', color: 'text-green-500',  icon: '✔' },
  paused:    { label: 'Paused',    color: 'text-yellow-500', icon: '⏸' },
  unread:    { label: 'Unread',    color: 'text-gray-500',   icon: '○' },
};

const levelConfig: Record<string, string> = {
  beginner:     'bg-emerald-950 text-emerald-400 border-emerald-900',
  intermediate: 'bg-blue-950 text-blue-400 border-blue-900',
  advanced:     'bg-red-950 text-red-400 border-red-900',
  general:      'bg-gray-900 text-gray-400 border-gray-800',
};

// Group books by category, sorted by category name
const grouped: Record<string, typeof books> = {};
for (const book of books) {
  const cat = book.category || 'uncategorized';
  if (!grouped[cat]) grouped[cat] = [];
  grouped[cat].push(book);
}
const categories = Object.keys(grouped).sort();
---

<BaseLayout title="Shelf | Genix">
  <TerminalWindow command="shelf find">
    <div class="space-y-8">

      <!-- Header -->
      <div class="space-y-3 pb-6 border-b border-gray-800">
        <div class="flex items-start justify-between gap-4">
          <div class="space-y-1">
            <h1 class="text-2xl text-white font-bold">TechShelf</h1>
            <p class="text-gray-300 text-sm leading-relaxed">
              {catalog.meta.description}
            </p>
          </div>
          <a
            href="https://github.com/m-mdy-m/TechShelf"
            target="_blank"
            rel="noopener"
            class="text-xs text-gray-500 hover:text-gray-300 transition-colors whitespace-nowrap pt-1">
            [github]
          </a>
        </div>

        <!-- Stats row -->
        {books.length > 0 && (
          <div class="flex flex-wrap gap-x-5 gap-y-1 text-xs text-gray-500 pt-1 font-mono">
            <span><span class="text-gray-300">{stats.total}</span> books</span>
            {Object.entries(stats.byStatus).map(([s, n]) => {
              const cfg = statusConfig[s];
              return (
                <span>
                  <span class={cfg?.color ?? 'text-gray-400'}>{n}</span>{' '}
                  {cfg?.label ?? s}
                </span>
              );
            })}
            {catalog.meta.last_updated && (
              <span class="ml-auto text-gray-700">updated {catalog.meta.last_updated}</span>
            )}
          </div>
        )}
      </div>

      <!-- Empty state -->
      {books.length === 0 && (
        <div class="text-center py-16 space-y-2">
          <p class="text-gray-500">The catalog is empty.</p>
          <a
            href="https://github.com/m-mdy-m/TechShelf"
            target="_blank"
            rel="noopener"
            class="text-xs text-gray-600 hover:text-gray-400 transition-colors">
            View on GitHub →
          </a>
        </div>
      )}

      <!-- Books by category -->
      {categories.map(cat => {
        const catBooks = grouped[cat];
        return (
          <section class="space-y-4">
            <!-- Category header -->
            <div class="flex items-center gap-3 pb-2 border-b border-gray-900">
              <span class="text-gray-600 text-xs font-mono">▶</span>
              <h2 class="text-base text-gray-300 font-semibold capitalize tracking-wide">
                {cat.replace(/-/g, ' ')}
              </h2>
              <span class="text-xs text-gray-700 font-mono">({catBooks.length})</span>
            </div>

            <!-- Books list -->
            <div class="space-y-3">
              {catBooks.map((book, idx) => {
                const sCfg = statusConfig[book.status ?? 'unread'];
                const lClass = levelConfig[book.level ?? 'general'] ?? levelConfig.general;
                return (
                  <article
                    class="group rounded border border-gray-900 bg-black/30 hover:border-gray-800 transition-colors duration-200 shelf-book"
                    style={`animation-delay: ${idx * 40}ms`}>
                    <div class="p-4 space-y-2">

                      <!-- Title row -->
                      <div class="flex items-start justify-between gap-4">
                        <div class="flex-1 min-w-0">
                          <h3 class="text-sm text-gray-200 font-medium leading-snug group-hover:text-white transition-colors">
                            {book.title}
                          </h3>
                          <p class="text-xs text-gray-500 mt-0.5">
                            {book.author.join(', ')}
                            {book.year_published && (
                              <span class="text-gray-700"> · {book.year_published}</span>
                            )}
                          </p>
                        </div>

                        <!-- Status badge -->
                        <div class={`flex items-center gap-1.5 text-xs shrink-0 ${sCfg?.color ?? 'text-gray-500'}`}>
                          <span class="font-mono">{sCfg?.icon ?? '○'}</span>
                          <span class="hidden sm:inline">{sCfg?.label ?? book.status}</span>
                        </div>
                      </div>

                      <!-- Description -->
                      {book.description && (
                        <p class="text-xs text-gray-400 leading-relaxed line-clamp-2">
                          {book.description}
                        </p>
                      )}

                      <!-- Meta row -->
                      <div class="flex flex-wrap items-center gap-2 pt-0.5">
                        {book.level && book.level !== 'general' && (
                          <span class={`text-xs px-2 py-0.5 rounded border font-mono ${lClass}`}>
                            {book.level}
                          </span>
                        )}

                        {book.tags && book.tags.slice(0, 4).map(tag => (
                          <span class="text-xs text-gray-600 bg-gray-950 px-1.5 py-0.5 rounded border border-gray-900 font-mono">
                            {tag}
                          </span>
                        ))}

                        {book.subcategory && (
                          <span class="text-xs text-gray-600 ml-auto font-mono">
                            {book.subcategory}
                          </span>
                        )}
                      </div>

                      <!-- Why read / Source -->
                      {(book.why_read || book.source?.online_url) && (
                        <div class="flex items-start justify-between gap-4 pt-1 border-t border-gray-900/60">
                          {book.why_read && (
                            <p class="text-xs text-gray-500 italic leading-relaxed flex-1 line-clamp-1">
                              {book.why_read}
                            </p>
                          )}
                          {book.source?.online_url && (
                            <a
                              href={book.source.online_url}
                              target="_blank"
                              rel="noopener"
                              class="text-xs text-gray-500 hover:text-gray-300 transition-colors shrink-0 font-mono">
                              [read →]
                            </a>
                          )}
                        </div>
                      )}
                    </div>
                  </article>
                );
              })}
            </div>
          </section>
        );
      })}

      <!-- Footer note -->
      {books.length > 0 && (
        <div class="pt-4 border-t border-gray-900 flex items-center justify-between text-xs text-gray-700">
          <span>synced from <a href="https://github.com/m-mdy-m/TechShelf" target="_blank" rel="noopener" class="hover:text-gray-500 transition-colors">github.com/m-mdy-m/TechShelf</a></span>
          <span class="font-mono">{stats.total} total</span>
        </div>
      )}

    </div>
  </TerminalWindow>
</BaseLayout>

<style>
  .shelf-book {
    animation: shelf-fade-in 0.4s ease-out forwards;
    opacity: 0;
  }

  @keyframes shelf-fade-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>