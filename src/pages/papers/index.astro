---
import BaseLayout from '@layouts/Layout.astro';
import TerminalWindow from '@components/TerminalWindow.astro';
import { getCollection } from 'astro:content';

const papers = (await getCollection('papers')).sort((a, b) =>
  a.id.localeCompare(b.id)
);

const styleConfig: Record<string, { label: string; color: string; bg: string; border: string }> = {
  academic:  { label: 'Academic',  color: 'text-blue-400',  bg: 'bg-blue-950/40',  border: 'border-blue-900' },
  personal:  { label: 'Personal',  color: 'text-purple-400', bg: 'bg-purple-950/40', border: 'border-purple-900' },
};

function repoSlug(repo: string) {
  const match = repo.match(/\/papers\/tree\/main\/papers\/(.+)$/);
  return match ? match[1] : null;
}
---

<BaseLayout title="Papers | Genix">
  <TerminalWindow command="ls papers">
    <div class="space-y-10">
      <!-- Header -->
      <div class="space-y-3 pb-6 border-b border-gray-800">
        <h1 class="text-2xl text-white font-bold">Papers</h1>
        <p class="text-base text-gray-300 leading-relaxed">
          Short-form formal writing — questions precise enough to need a definition,
          a proof, or a worked example instead of a blog post.
        </p>
        <p class="text-sm text-gray-500">
          Source, LaTeX, and bibliography live in
          <a href="https://github.com/papyrxis/papers" target="_blank" rel="noopener" class="text-gray-400 hover:text-gray-200 underline underline-offset-2">
            github.com/papyrxis/papers
          </a>.
        </p>
      </div>

      <!-- Papers list -->
      <div class="space-y-8">
        {papers.map((paper, idx) => {
          const style = styleConfig[paper.data.style];
          const slug = repoSlug(paper.data.repository);

          return (
            <article
              class="group space-y-4 pb-8 border-b border-gray-900 last:border-0 animate-fade-in"
              style={`animation-delay: ${idx * 100}ms`}>

              <!-- Title and style badge -->
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1 space-y-1">
                  <span class="text-xs text-gray-600 font-mono">
                    {String(idx + 1).padStart(2, '0')}
                  </span>
                  <h2 class="text-xl text-white font-bold leading-tight">
                    {paper.data.title}
                  </h2>
                </div>
                <div class={`flex items-center gap-2 text-xs ${style.color} ${style.bg} px-3 py-1.5 rounded border ${style.border} whitespace-nowrap`}>
                  <span>{style.label}</span>
                </div>
              </div>

              <!-- Abstract -->
              <p class="text-sm text-gray-400 leading-relaxed">
                <span class="text-gray-600 font-semibold">Abstract — </span>
                {paper.data.abstract}
              </p>

              <!-- Keywords -->
              {paper.data.keywords.length > 0 && (
                <div class="flex flex-wrap gap-2">
                  {paper.data.keywords.map(kw => (
                    <span class="text-xs text-gray-400 bg-gray-950 px-2.5 py-1 rounded border border-gray-900">
                      {kw}
                    </span>
                  ))}
                </div>
              )}

              <!-- Links -->
              <div class="flex flex-wrap items-center gap-4 text-sm pt-1">
                {slug && (
                  <a
                    href={`/papers/${slug}`}
                    class="text-gray-300 hover:text-white transition-colors">
                    [read]
                  </a>
                )}
                <a
                  href={paper.data.repository}
                  target="_blank"
                  rel="noopener"
                  class="text-gray-500 hover:text-gray-300 transition-colors">
                  [source]
                </a>
                {paper.data.pdf && (
                  <a
                    href={paper.data.pdf}
                    target="_blank"
                    rel="noopener"
                    class="text-gray-500 hover:text-gray-300 transition-colors">
                    [pdf]
                  </a>
                )}
                {paper.data.date && (
                  <span class="text-xs text-gray-700">{paper.data.date}</span>
                )}
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </TerminalWindow>
</BaseLayout>

<style>
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 0.5s ease-out forwards;
    opacity: 0;
  }
</style>
